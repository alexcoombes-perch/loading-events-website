---
layout: base.njk
permalink: /gallery/
eleventyComputed:
  page_title: "{{ gallery.page_title }}"
---
<section class="section--tight">
  <div class="container reveal">
    <h1>{{ gallery.heading }}</h1>
    <div class="prose">
      {% for para in gallery.intro_paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>
    <a class="instagram-follow" href="{{ site.instagram_url }}" target="_blank" rel="noopener">Follow along {{ site.instagram_handle }}</a>
  </div>
</section>

<section class="section--tight" style="padding-top: 0;">
  <div class="container">
    <div class="gallery-filter" id="galleryFilter">
      <button type="button" class="is-active" data-filter="all">All</button>
      {% for cat in gallery.categories %}
      <button type="button" data-filter="{{ cat.key }}">{{ cat.label }}</button>
      {% endfor %}
    </div>

    <div class="gallery-grid">
      {% for image in gallery.images %}
      <a href="{{ image.src }}" target="_blank" rel="noopener" data-category="{{ image.category }}">
        <img src="{{ image.src }}" alt="{{ image.alt }}" loading="lazy">
      </a>
      {% endfor %}
    </div>

    <p class="text-center mt-lg" style="font-style: italic; color: var(--ink-soft);">{{ gallery.closing_line }}</p>
  </div>
</section>

<script>
  (function () {
    var buttons = document.querySelectorAll('#galleryFilter button');
    var tiles = document.querySelectorAll('.gallery-grid a');
    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        buttons.forEach(function (b) { b.classList.remove('is-active'); });
        btn.classList.add('is-active');
        var filter = btn.getAttribute('data-filter');
        tiles.forEach(function (tile) {
          var show = filter === 'all' || tile.getAttribute('data-category') === filter;
          tile.style.display = show ? '' : 'none';
        });
      });
    });
  })();
</script>
