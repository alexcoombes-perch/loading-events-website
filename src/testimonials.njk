---
layout: base.njk
permalink: /testimonials/
eleventyComputed:
  page_title: "{{ testimonials.page_title }}"
---
<section class="section--tight">
  <div class="container">
    <span class="eyebrow">Kind words</span>
    <h1>{{ testimonials.heading }}</h1>
    <div class="prose">
      {% for para in testimonials.intro_paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>

    {% if testimonials.accent_image %}
    <div class="reveal" style="max-width: 480px; margin: var(--space-lg) 0;">
      <img src="{{ testimonials.accent_image }}" alt="{{ testimonials.accent_image_alt }}" style="border-radius: 14px; width: 100%; object-fit: cover; box-shadow: var(--shadow-soft);" loading="lazy">
    </div>
    {% endif %}

    {% if testimonials.testimonials and testimonials.testimonials.length %}
    <div class="testimonial-grid">
      {% for t in testimonials.testimonials %}
      <div class="testimonial-card reveal reveal--{{ loop.index }}">
        <p>{{ t.quote }}</p>
        <p class="names">{{ t.names }}</p>
        <p style="color: var(--ink-soft); font-size: 0.85rem;">{{ t.date }}</p>
      </div>
      {% endfor %}
    </div>
    {% elif testimonials.no_reviews %}
    <div class="prose reveal" style="max-width: 580px; margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: 1px solid rgba(107,17,82,0.12);">
      <span class="eyebrow">{{ testimonials.no_reviews.heading }}</span>
      <p>{{ testimonials.no_reviews.text }}</p>
    </div>
    {% endif %}

    {% if testimonials.cta_line %}
    <div class="text-center mt-lg reveal">
      <p class="script" style="font-size: 1.7rem;">{{ testimonials.cta_line }}</p>
      <a class="btn" href="{{ testimonials.cta_url }}">{{ testimonials.cta_label }}</a>
    </div>
    {% endif %}
  </div>
</section>
