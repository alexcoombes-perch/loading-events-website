---
layout: base.njk
permalink: /services/
eleventyComputed:
  page_title: "{{ services.page_title }}"
---
<section class="section--tight">
  <div class="container">
    <span class="eyebrow">What I offer</span>
    <h1>{{ services.heading }}</h1>
    <div class="prose">
      {% for para in services.intro_paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>

    <div class="services-grid">
      {% for item in services.services %}
      <div class="service-card">
        <h3>{{ item.name }}</h3>
        <p>{{ item.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{% if services.accent_image %}
<div class="container">
  <img src="{{ services.accent_image }}" alt="{{ services.accent_image_alt }}" style="border-radius: 8px; max-height: 480px; width: 100%; object-fit: cover;">
</div>
{% endif %}

{% if services.faq %}
<section class="section--tight">
  <div class="container">
    <span class="eyebrow">Good to know</span>
    <h2>A few questions couples ask</h2>
    <div class="faq-list">
      {% for item in services.faq %}
      <div class="faq-item">
        <h3>{{ item.question }}</h3>
        <p>{{ item.answer }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<section class="section--blue text-center">
  <div class="container">
    <p class="script" style="font-size: 1.6rem; color: var(--white);">{{ services.closing_line }}</p>
    <a class="btn btn--outline" href="{{ services.cta_url }}">{{ services.cta_label }}</a>
  </div>
</section>
