---
layout: base.njk
permalink: /approach/
eleventyComputed:
  page_title: "{{ approach.page_title }}"
---
<section class="section--tight">
  <div class="container">
    <span class="eyebrow">How I work</span>
    <h1>{{ approach.heading }}</h1>
    <div class="prose">
      {% for para in approach.intro_paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>
  </div>
</section>

{% if approach.accent_image %}
<div class="container reveal">
  <img src="{{ approach.accent_image }}" alt="{{ approach.accent_image_alt }}" style="border-radius: 14px; max-height: 480px; width: 100%; object-fit: cover; box-shadow: var(--shadow-soft);">
</div>
{% endif %}

<section>
  <div class="container">
    {% for block in approach.sections %}
    <div class="approach-block reveal reveal--{{ loop.index }}">
      <h2>{{ block.heading }}</h2>
      <div class="prose">
        {% for para in block.paragraphs %}
        <p>{{ para }}</p>
        {% endfor %}
        {% if block.list %}
        <p><strong>{{ block.list_intro }}</strong></p>
        <ul>
          {% for item in block.list %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<section class="section--wine">
  <span class="watermark" style="top: -6%; left: -3%;">feeling</span>
  <div class="container prose--center reveal" style="max-width: 700px;">
    <h2>{{ approach.closing.heading }}</h2>
    {% for para in approach.closing.paragraphs %}
    <p>{{ para }}</p>
    {% endfor %}
  </div>
</section>
