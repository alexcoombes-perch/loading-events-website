---
layout: base.njk
permalink: /approach/
eleventyComputed:
  page_title: "{{ approach.page_title }}"
---
<section class="section--tight">
  <div class="container">
    <span class="eyebrow">How I work</span>
    <h1>{{ approach.heading }}</h1>
    <div class="prose">
      {% for para in approach.intro_paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>
  </div>
</section>

{% if approach.accent_image %}
<div class="container reveal">
  <img src="{{ approach.accent_image }}" alt="{{ approach.accent_image_alt }}" style="border-radius: 14px; max-height: 480px; width: 100%; object-fit: cover; box-shadow: var(--shadow-soft);" loading="lazy">
</div>
{% endif %}

{% for block in approach.sections %}
<section class="{{ 'section--blush' if loop.index is even else '' }}">
  <div class="container">
    <div class="split reveal">
      {% if loop.index is even %}
      <img src="{{ block.image }}" alt="{{ block.image_alt }}" loading="lazy">
      {% endif %}
      <div class="approach-block">
        <h2>{{ block.heading }}</h2>
        <div class="prose">
          {% for para in block.paragraphs %}
          <p>{{ para }}</p>
          {% endfor %}
          {% if block.list %}
          <p><strong>{{ block.list_intro }}</strong></p>
          <ul>
            {% for item in block.list %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
      </div>
      {% if loop.index is odd %}
      <img src="{{ block.image }}" alt="{{ block.image_alt }}" loading="lazy">
      {% endif %}
    </div>
  </div>
</section>
{% if loop.index == 2 and approach.photo_moment %}
<section class="photo-moment section--flush" style="background-image: url('{{ approach.photo_moment.image }}');" role="img" aria-label="{{ approach.photo_moment.image_alt }}">
  <p class="photo-moment__quote reveal script">{{ approach.photo_moment.quote }}</p>
</section>
{% endif %}
{% endfor %}

<section class="section--wine">
  <div class="container prose--center reveal" style="max-width: 700px;">
    <h2>{{ approach.closing.heading }}</h2>
    {% for para in approach.closing.paragraphs %}
    <p>{{ para }}</p>
    {% endfor %}
  </div>
</section>
