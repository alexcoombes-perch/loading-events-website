---
layout: base.njk
permalink: /gallery/
eleventyComputed:
  page_title: "{{ gallery.page_title }}"
---
<section class="section--tight">
  <div class="container">
    <span class="eyebrow">Real weddings</span>
    <h1>{{ gallery.heading }}</h1>
    <div class="prose">
      {% for para in gallery.intro_paragraphs %}
      <p>{{ para }}</p>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section--tight" style="padding-top: 0;">
  <div class="container">
    <div class="gallery-grid">
      {% for image in gallery.images %}
      <a href="{{ image.src }}" target="_blank" rel="noopener">
        <img src="{{ image.src }}" alt="{{ image.alt }}" loading="lazy">
      </a>
      {% endfor %}
    </div>
    <p class="text-center mt-lg" style="font-style: italic; color: var(--ink-soft);">{{ gallery.closing_line }}</p>
  </div>
</section>
